# One line per value. If you use double quotes, close them on the SAME line (no line break inside the secret).
NODE_ENV=development
PORT=5000

# Required: MongoDB Atlas or local — e.g. mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CLIENT_URL=http://localhost:5173
HOD_NAME=Dr. Department Head

# Cloudinary: cloud name is usually lowercase in the dashboard (not the display label)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Chatbot (Google AI Studio / Gemini API key)
GEMINI_API_KEY=AIzaSyDZfNsEPuiavWRGc4ofUb5GatEUjJwl2T8
# Examples: gemini-1.5-flash, gemini-2.0-flash — set if the default fails in your project
GEMINI_MODEL=gemini-1.5-flash
